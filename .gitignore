# Secrets — NEVER commit these
storage/.secret_key
storage/.api_key
config/telegram.json

# Database — contains live alert data
storage/*.db
storage/*.db-wal
storage/*.db-shm

# Trained model — large binary, regenerated by train_model.py
model/random_forest_model.pkl
model/scaler.pkl
model/label_encoder.pkl

# Threat intelligence cache — downloaded at runtime
data/ipsum_tor_list.txt

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Logs — runtime generated
logs/*.log
logs/*.log.*

# Virtual environment — never commit this
venv/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
