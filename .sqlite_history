SELECT COUNT(*) as total_alerts FROM alerts;
SELECT detection_method, COUNT(*) as count
FROM alerts
GROUP BY detection_method;
SELECT
    strftime('%H:%M:%S', timestamp) as time,
    source_ip,
    attack_type,
    detection_method,
    severity,
    ROUND(confidence, 2) as conf,
    country,
    status
FROM alerts
ORDER BY timestamp DESC
LIMIT 10;
SELECT
    strftime('%H:%M:%S', timestamp) as time,
    source_ip,
    attack_type,
    explanation
FROM alerts
WHERE source_component = 'honeypot'
ORDER BY timestamp DESC;
.exit
SELECT COUNT(*) as total_alerts FROM alerts;
SELECT severity, COUNT(*) as count
FROM alerts
GROUP BY severity
ORDER BY CASE severity
  WHEN 'CRITICAL' THEN 1
  WHEN 'HIGH'     THEN 2
  WHEN 'MEDIUM'   THEN 3
  WHEN 'LOW'      THEN 4
END;
SELECT detection_method, COUNT(*) as count
FROM alerts
GROUP BY detection_method;
.exit
PRAGMA table_info(alerts);
SELECT * FROM alerts
ORDER BY timestamp DESC
LIMIT 1;
.exit
